{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "esModuleInterop": true,
    "verbatimModuleSyntax": false,
    "allowImportingTsExtensions": false,
    "moduleResolution": "node",
    "module": "esnext",
    "target": "ES2022",
    "types": ["jest", "@testing-library/jest-dom", "node", "vite/client"]
  },
  "include": ["src/**/*", "src/types/**/*"]
}
